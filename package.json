{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "qa:build": "php scripts/qa/build_postman_collection.php",
        "qa:env": "php scripts/qa/export_qa_env.php",
        "qa:newman": "newman run storage/qa/postman/LimosudCars_API_QA.postman_collection.json -e storage/qa/postman/LimosudCars_API_QA.postman_environment.json --reporters cli,json --reporter-json-export storage/qa/reports/newman-results.json --delay-request 100",
        "qa:workflow": "powershell -ExecutionPolicy Bypass -File scripts/qa/run_qa_workflow.ps1",
        "qa:frontend-guide": "php scripts/qa/generate_frontend_integration_guide.php",
        "qa:frontend-workflows": "php scripts/qa/generate_frontend_workflows.php",
        "qa:audit-secrets": "php scripts/qa/audit_committable_secrets.php"
    },
    "devDependencies": {
        "newman": "^6.2.1",
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
